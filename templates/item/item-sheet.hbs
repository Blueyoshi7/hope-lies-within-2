<form class="{{cssClass}} hlw-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Name" /></h1>
      <div class="identity-grid">
        <label>Quelle <input name="system.source" type="text" value="{{system.source}}" /></label>
        <label>Tier <input name="system.tier" type="number" value="{{system.tier}}" /></label>
      </div>
    </div>
  </header>

  {{#if isSkill}}
    <section class="form-grid">
      <label>Skill-Art <input name="system.skillType" type="text" value="{{system.skillType}}" /></label>
      <label>Kosten <input name="system.cost" type="text" value="{{system.cost}}" /></label>
      <label>Cast Time <input name="system.castTime" type="text" value="{{system.castTime}}" /></label>
      <label>Range <input name="system.range" type="text" value="{{system.range}}" /></label>
      <label>Schaden / Heilung <input name="system.damage" type="text" value="{{system.damage}}" /></label>
      <label>Cooldown <span><input name="system.cooldown.value" type="number" value="{{system.cooldown.value}}" /> / <input name="system.cooldown.max" type="number" value="{{system.cooldown.max}}" /></span></label>
      <label>Primaer <input name="system.scaling.primary" type="text" value="{{system.scaling.primary}}" /></label>
      <label>Sekundaer <input name="system.scaling.secondary" type="text" value="{{system.scaling.secondary}}" /></label>
      <label>Tertiaer <input name="system.scaling.tertiary" type="text" value="{{system.scaling.tertiary}}" /></label>
    </section>
    <label class="stacked">Effekt
      <textarea name="system.effect">{{system.effect}}</textarea>
    </label>
  {{else}}
    <section class="form-grid">
      <label>Anzahl <input name="system.quantity" type="number" value="{{system.quantity}}" /></label>
      <label>Preis <input name="system.price" type="text" value="{{system.price}}" /></label>
      <label>Slot <input name="system.slot" type="text" value="{{system.slot}}" /></label>
      <label>Schaden <input name="system.damage" type="text" value="{{system.damage}}" /></label>
      <label>Ruestwert <input name="system.armor" type="text" value="{{system.armor}}" /></label>
      <label>Range <input name="system.range" type="text" value="{{system.range}}" /></label>
      <label>Ausgeruestet <input name="system.equipped" type="checkbox" {{checked system.equipped}} /></label>
    </section>
    <label class="stacked">Effekt
      <textarea name="system.effect">{{system.effect}}</textarea>
    </label>
  {{/if}}

  <label class="stacked">Beschreibung
    <textarea name="system.description">{{system.description}}</textarea>
  </label>
</form>

<form class="{{cssClass}} hlw-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{profileImage}}" title="{{actor.name}}" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Charaktername" /></h1>
      <div class="identity-grid">
        <label>Spieler <input name="system.identity.player" type="text" value="{{system.identity.player}}" /></label>
        <label>Level <input name="system.progression.level" type="number" value="{{system.progression.level}}" /></label>
        <label>Klasse <input name="system.progression.class" type="text" value="{{system.progression.class}}" /></label>
        <label>Job <input name="system.progression.job" type="text" value="{{system.progression.job}}" /></label>
        <label>Titel <input name="system.progression.title" type="text" value="{{system.progression.title}}" /></label>
        <label>Insignie <input name="system.progression.insignia" type="text" value="{{system.progression.insignia}}" /></label>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Charakter</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="insignia">Insignien</a>
    <a class="item" data-tab="inventory">Inventar</a>
    <a class="item" data-tab="notes">Notizen</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="main">
      <section class="resource-grid">
        <label>Lebenspunkte
          <span><input name="system.resources.hp.value" type="number" value="{{system.resources.hp.value}}" /> / <input name="system.resources.hp.max" type="number" value="{{system.resources.hp.max}}" /></span>
        </label>
        <label>Bewegung
          <span><input name="system.resources.movement.value" type="number" value="{{system.resources.movement.value}}" /> {{system.resources.movement.units}}</span>
        </label>
        <label>Aktionspunkte
          <span><input name="system.resources.actionPoints.value" type="number" value="{{system.resources.actionPoints.value}}" /> / <input name="system.resources.actionPoints.max" type="number" value="{{system.resources.actionPoints.max}}" /></span>
        </label>
        <label>Korruption
          <span><input name="system.resources.corruption.value" type="number" value="{{system.resources.corruption.value}}" /> / <input name="system.resources.corruption.max" type="number" value="{{system.resources.corruption.max}}" /></span>
        </label>
      </section>

      <section class="defense-grid">
        <label>Physische Verteidigung
          <input name="system.defenses.physical.value" type="number" value="{{system.defenses.physical.value}}" />
        </label>
        <label>Magische Verteidigung
          <input name="system.defenses.magical.value" type="number" value="{{system.defenses.magical.value}}" />
        </label>
      </section>

      <section class="action-grid">
        <div class="action-toggle {{#if canAct}}is-ready{{else}}is-spent{{/if}}">
          <strong>Aktionspunkte</strong>
          <span>{{system.resources.actionPoints.value}} / {{system.resources.actionPoints.max}}</span>
        </div>
        <button type="button" class="action-toggle {{#if system.actions.movement.available}}is-ready{{else}}is-spent{{/if}}" data-toggle-action="movement">
          <strong>Bewegung</strong>
          <span>{{#if system.actions.movement.available}}bereit{{else}}verbraucht{{/if}}</span>
        </button>
        <button type="button" class="action-toggle end-turn" data-end-turn>
          <strong>Zug beenden</strong>
          <span>weiter</span>
        </button>
      </section>

      <section class="standard-actions">
        <h2>Standardaktionen</h2>
        <div class="action-grid">
          <button type="button" class="action-toggle {{#unless canAct}}is-spent{{/unless}}" data-standard-action="attack" {{#unless canAct}}disabled{{/unless}}>
            <strong>Normaler Angriff</strong>
            <span>1 AP</span>
          </button>
          <button type="button" class="action-toggle {{#unless canAct}}is-spent{{/unless}}" data-standard-action="item" {{#unless canAct}}disabled{{/unless}}>
            <strong>Item verwenden</strong>
            <span>1 AP</span>
          </button>
          <button type="button" class="action-toggle {{#unless canAct}}is-spent{{/unless}}" data-standard-action="defend" {{#unless canAct}}disabled{{/unless}}>
            <strong>Abwehrhaltung</strong>
            <span>1 AP</span>
          </button>
        </div>
      </section>

      <section class="resistance-panel">
        <h2>Veranlagung</h2>
        <div class="resistance-grid">
          {{#each system.affinities as |affinity key|}}
            <label>
              <span>{{affinity.label}}</span>
              <input name="system.affinities.{{key}}.value" type="number" value="{{affinity.value}}" />
            </label>
          {{/each}}
        </div>
      </section>

      <section class="two-column">
        <div>
          <h2>Attribute</h2>
          <div class="attribute-grid">
            {{#each system.attributes as |attribute key|}}
              <label>
                <span>{{attribute.abbr}}</span>
                <small>{{attribute.label}}</small>
                <input name="system.attributes.{{key}}.value" type="number" value="{{attribute.value}}" />
              </label>
            {{/each}}
          </div>
        </div>

        <div>
          <h2>World-Skills</h2>
          <div class="world-skill-list">
            {{#each worldSkills as |skill|}}
              <div class="world-skill-row">
                <button type="button" data-roll-world-skill="{{skill.key}}">W20</button>
                <div>
                  <strong>{{skill.label}}</strong>
                  <small>{{skill.attributeLabels}}</small>
                </div>
                <span>{{skill.base}}</span>
                <input name="system.worldSkills.{{skill.key}}.bonus" type="number" value="{{skill.bonus}}" />
                <strong>{{skill.total}}</strong>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="skills">
      <h2>Spieler- und Klassenskills</h2>
      <ol class="item-list">
        {{#each itemsByType.skills as |item|}}
          <li class="item-row {{#unless item.canUse}}is-disabled{{/unless}}" data-item-id="{{item.id}}" draggable="true">
            <button type="button" data-use-skill {{#unless item.canUse}}disabled{{/unless}}>{{#if item.isPending}}Abbrechen{{else}}Nutzen{{/if}}</button>
            <strong>{{item.name}}</strong>
            <span>{{item.system.skillType}}</span>
            <span>{{item.activationLabel}}</span>
            <span>{{item.system.element}}</span>
            <span>CD {{item.system.cooldown.value}} / {{item.system.cooldown.max}}</span>
            <span>Range {{item.system.range}}</span>
            <span>{{item.system.damage}}</span>
            {{#if ../isGM}}<button type="button" class="danger-button" data-delete-skill>X</button>{{/if}}
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="insignia">
      <h2>Insignien</h2>
      <div class="insignia-grid">
        {{#each insigniaSlots as |slot|}}
          <section class="insignia-slot">
            <label class="insignia-active"><input name="system.progression.activeInsignia" type="radio" value="{{slot.key}}" {{checked slot.active}} /> Aktiv</label>
            <img src="{{slot.image}}" data-edit="system.insigniaSlots.{{slot.key}}.image" title="{{slot.name}}" />
            <label>Name <input name="system.insigniaSlots.{{slot.key}}.name" type="text" value="{{slot.name}}" /></label>
            <label>Bild <input name="system.insigniaSlots.{{slot.key}}.image" type="text" value="{{slot.image}}" /></label>
            <label>Beschreibung <textarea name="system.insigniaSlots.{{slot.key}}.description">{{slot.description}}</textarea></label>
          </section>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <h2>Inventar</h2>
      <section class="inventory-gold-bar">
        <div>
          <span>Gold</span>
          <strong>{{system.resources.gold.value}}</strong>
        </div>
        <label>Gold geben
          <span><input data-gold-amount type="number" min="0" placeholder="Betrag" /><button type="button" data-give-gold>Geben</button></span>
        </label>
        {{#if isGM}}
          <label>GM Gold +
            <span><input data-add-gold-amount type="number" min="0" placeholder="Betrag" /><button type="button" data-add-gold>Hinzufügen</button></span>
          </label>
        {{/if}}
      </section>
      <h3>Waffen</h3>
      <ol class="item-list">
        {{#each itemsByType.weapons as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <input type="checkbox" data-toggle-equipped {{checked item.equipped}} title="Ausgeruestet" />
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>{{item.damageCategoryLabel}}</span>
            <span>{{item.damageTypeLabel}}</span>
            <span>{{item.system.damage}}</span>
            <span>R {{item.system.range}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Ruestung</h3>
      <ol class="item-list">
        {{#each itemsByType.armor as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <input type="checkbox" data-toggle-equipped {{checked item.equipped}} title="Ausgeruestet" />
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>RW {{item.system.armor}}</span>
            <span>{{item.system.slot}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Ausrüstung</h3>
      <ol class="item-list">
        {{#each itemsByType.equipment as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <input type="checkbox" data-toggle-equipped {{checked item.equipped}} title="Ausgeruestet" />
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>{{item.system.slot}}</span>
            <span>{{item.system.effect}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Verbrauchbares & Material</h3>
      <ol class="item-list">
        {{#each itemsByType.consumables as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.effect}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
        {{#each itemsByType.materials as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.source}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Naturgegenstände</h3>
      <ol class="item-list">
        {{#each itemsByType.natural as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.source}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Mineralien</h3>
      <ol class="item-list">
        {{#each itemsByType.minerals as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.source}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Müll</h3>
      <ol class="item-list">
        {{#each itemsByType.junk as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.source}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
      <h3>Essen & Trinken</h3>
      <ol class="item-list">
        {{#each itemsByType.foodDrink as |item|}}
          <li class="item-row inventory-row" data-item-id="{{item.id}}" data-show-item-details>
            <span></span>
            <img src="{{item.img}}" alt="" />
            <strong>{{item.name}}</strong>
            <span>x{{item.system.quantity}}</span>
            <span>{{item.system.effect}}</span>
            <button type="button" data-edit-owned-item>Bearbeiten</button>
            <button type="button" data-give-owned-item>Geben</button>
            <button type="button" data-consume-owned-item>Verbr.</button>
            <button type="button" data-discard-owned-item>Weg</button>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      <h2>Charakternotizen</h2>
      <textarea name="system.identity.notes">{{system.identity.notes}}</textarea>
    </div>
  </section>
</form>
